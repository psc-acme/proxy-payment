{
    "name": "psc-acme/proxy-payment",
    "description": "Package proxy-payment for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ProxyPayment\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "symfony/validator": "^7.0",
        "league/commonmark": "^2.0",
        "psc-acme/gateway-payment": "^1.0",
        "psc-acme/service-user": "^1.0",
        "psc-acme/module-user": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "infection/infection": "^0.27",
        "vimeo/psalm": "^5.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}